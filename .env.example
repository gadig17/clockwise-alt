# ──────────────────────────────────────────────────
# clockwise-alt — Script Properties Reference
# ──────────────────────────────────────────────────
# Set these values in the Apps Script editor:
#   File > Project settings > Script properties
#
# DO NOT commit real values. This file documents the
# required keys and example values.
# ──────────────────────────────────────────────────

# OAuth2 credentials from Google Cloud Console
OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-client-secret

# Personal Google Calendar ID (usually your personal email)
PERSONAL_CALENDAR_ID=you@gmail.com

# Work calendar ID ("primary" uses the default calendar)
WORK_CALENDAR_ID=primary

# Timezone (IANA format)
TIMEZONE=America/New_York

# Work hours (24h format)
WORK_HOURS_START=09:00
WORK_HOURS_END=17:00

# Working days (0=Sun, 1=Mon, ..., 6=Sat)
WORK_DAYS=1,2,3,4,5

# Lunch scheduling
LUNCH_WINDOW_START=11:30
LUNCH_WINDOW_END=13:30
LUNCH_PREFERRED_START=12:00
LUNCH_MAX_MINUTES=60
LUNCH_MIN_MINUTES=30

# Sync settings
SYNC_LOOKAHEAD_DAYS=14
# Set to "true" to sync personal events outside work hours (weekday evenings/mornings)
SYNC_OUTSIDE_WORK_HOURS=false

# Busy block appearance
BUSY_BLOCK_TITLE=Busy (Synced)
